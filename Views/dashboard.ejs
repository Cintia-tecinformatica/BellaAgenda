<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BellaAgenda - Dashboard</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <header class="main-header">
        <h1>Olá, <%= user.nome %></h1>
        <a href="/auth/logout" class="btn-logout">Sair</a>
    </header>

    <main class="dashboard-container">
        <!-- SEÇÃO: NOVO AGENDAMENTO -->
        <section class="card appointment-form">
            <h2>[ Novo Agendamento ]</h2>
            <form action="/appointments/novo" method="POST">
                <div class="form-group">
                    <label for="servico">Serviço</label>
                    <select id="servico" name="servico" required>
                        <option value="" disabled selected>Selecione um serviço</option>
                        <option value="Corte">Corte</option>
                        <option value="Escova">Escova</option>
                        <option value="Manicure">Manicure</option>
                        <option value="Pedicure">Pedicure</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="data">Data</label>
                    <input type="date" id="data" name="data" required>
                </div>

                <div class="form-group">
                    <label for="horario">Horário</label>
                    <input type="time" id="horario" name="horario" required>
                </div>

                <button type="submit" class="btn-submit">[ Salvar ]</button>
            </form>
        </section>

        <!-- SEÇÃO: MEUS AGENDAMENTOS -->
        <section class="card appointment-list">
            <h2>Meus Agendamentos</h2>
            
            <% if (appointments.length === 0) { %>
                <p class="empty-msg">Nenhum agendamento marcado ainda.</p>
            <% } else { %>
                <div class="table-responsive">
                    <table class="appointments-table">
                        <thead>
                            <tr>
                                <th>Serviço</th>
                                <th>Data</th>
                                <th>Horário</th>
                                <th>Ação</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% appointments.forEach(function(item) { %>
                                <tr>
                                    <td>✔ <%= item.servico %></td>
                                    <!-- Formatando a data de AAAA-MM-DD para DD/MM/AAAA de forma simples -->
                                    <td><%= item.data.split('-').reverse().join('/') %></td>
                                    <td><%= item.horario %></td>
                                    <td>
                                        <form action="/appointments/excluir/<%= item.id %>" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir este agendamento?');">
                                            <button type="submit" class="btn-delete">[Excluir]</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>
    </main>
</body>
</html>